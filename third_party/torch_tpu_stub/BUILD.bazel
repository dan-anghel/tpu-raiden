# Empty stub package for the torch_tpu Bazel module.
# Lets JAX-only / OSS builds resolve the torch_tpu bazel_dep without the real
# (not-yet-public) torch_tpu source. The benchmark targets are pure JAX and
# reference no @torch_tpu// targets, so an empty package is sufficient.

load("@nanobind_bazel//:build_defs.bzl", "nanobind_extension")
load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library", "cc_test")
load("@rules_python//python:defs.bzl", "py_library", "py_test")

package(default_visibility = ["//visibility:public"])
